# frozen_string_literal: true

source "https://rubygems.org"

# Core Jekyll build (4.3+ required for sass-embedded via jekyll-sass-converter 3.x)
gem "jekyll", "~> 4.4"

# Plugins used by this site (see _config.yml)
gem "jekyll-seo-tag"
gem "jekyll-sitemap"
gem "jekyll-feed", "~> 0.17.0"
gem "jekyll-gist", "~> 1.5"
gem "jemoji"

# Markdown parser used by GitHub Pages/Jekyll defaults
gem "kramdown-parser-gfm"

# Use sass-embedded (Dart Sass) instead of sassc/libSass to avoid Ruby 4 segfaults
gem "jekyll-sass-converter", "~> 3.0"

# Required for local serve on recent Ruby versions
gem "webrick"

# CSV moved to a default gem in newer Ruby versions
# gem "csv", "~> 3.2"

# BigDecimal moved to a default gem in newer Ruby versions
gem "bigdecimal", "~> 3.1"

# Dependency used by Jekyll live reload
gem "em-websocket", "~> 0.5.3"
